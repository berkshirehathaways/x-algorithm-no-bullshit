{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/berkshirehathaways/x-algorithm-no-bullshit/blob/main/claims/schema.json",
  "title": "X Algorithm claim registry",
  "type": "object",
  "required": ["schema_version", "registry_version", "reviewed_at", "upstream", "claims"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "registry_version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "reviewed_at": {"type": "string", "format": "date"},
    "upstream": {"$ref": "#/$defs/upstream"},
    "claims": {
      "type": "array",
      "minItems": 19,
      "items": {"$ref": "#/$defs/claim"}
    }
  },
  "$defs": {
    "upstream": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repository", "commit", "checked_at"],
      "properties": {
        "repository": {"const": "xai-org/x-algorithm"},
        "commit": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
        "checked_at": {"type": "string", "format": "date"}
      }
    },
    "claim": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "claim", "verdict", "practical_implication", "evidence_summary", "upstream_commit", "sources"],
      "properties": {
        "id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$"},
        "claim": {"type": "string", "minLength": 1},
        "verdict": {"enum": ["confirmed-current", "legacy-only", "inferred", "unsupported", "unknown", "contradicted"]},
        "practical_implication": {"type": "string", "minLength": 1},
        "evidence_summary": {"type": "string", "minLength": 1},
        "upstream_commit": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
        "sources": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/source"}}
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repository", "commit", "path", "line_start", "line_end", "url"],
      "properties": {
        "repository": {"type": "string", "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$"},
        "commit": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
        "path": {"type": "string", "minLength": 1},
        "line_start": {"type": "integer", "minimum": 1},
        "line_end": {"type": "integer", "minimum": 1},
        "url": {"type": "string", "pattern": "^https://github\\.com/[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+/blob/[0-9a-f]{40}/.+#L[1-9][0-9]*-L[1-9][0-9]*$"}
      }
    }
  }
}
