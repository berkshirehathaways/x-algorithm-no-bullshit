{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/berkshirehathaways/x-algorithm-no-bullshit/blob/main/contracts/x-post-optimize.response.schema.json",
  "title": "x_post.optimize.v1 response",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "status",
    "evidence_ledger",
    "hooks",
    "variants",
    "assumptions",
    "rejections",
    "launch_plan",
    "measurement_plan",
    "limitations",
    "extensions"
  ],
  "$defs": {
    "claimId": { "type": "string", "minLength": 1 },
    "verdict": { "enum": ["confirmed-current", "legacy-only", "inferred", "unsupported", "unknown", "contradicted"] },
    "assertion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["text", "kind", "claim_ids", "verdicts"],
      "properties": {
        "text": { "type": "string", "minLength": 1 },
        "kind": { "enum": ["fact", "inference", "assumption", "hypothesis"] },
        "claim_ids": { "type": "array", "items": { "$ref": "#/$defs/claimId" }, "uniqueItems": true },
        "verdicts": { "type": "array", "items": { "$ref": "#/$defs/verdict" }, "uniqueItems": true }
      },
      "allOf": [
        {
          "if": { "properties": { "kind": { "enum": ["fact", "inference"] } }, "required": ["kind"] },
          "then": {
            "properties": {
              "claim_ids": { "minItems": 1 },
              "verdicts": { "minItems": 1 }
            }
          }
        },
        {
          "if": { "properties": { "kind": { "enum": ["assumption", "hypothesis"] } }, "required": ["kind"] },
          "then": {
            "properties": {
              "claim_ids": { "maxItems": 0 },
              "verdicts": { "maxItems": 0 }
            }
          }
        }
      ]
    }
  },
  "properties": {
    "schema_version": { "const": "x_post.optimize.v1" },
    "status": { "enum": ["ready", "needs-evidence", "rejected"] },
    "evidence_ledger": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["claim_id", "verdict", "freshness", "allowed_wording"],
        "properties": {
          "claim_id": { "$ref": "#/$defs/claimId" },
          "verdict": { "$ref": "#/$defs/verdict" },
          "freshness": {
            "type": "object",
            "additionalProperties": false,
            "required": ["checked_at", "state"],
            "properties": {
              "checked_at": { "type": "string", "format": "date" },
              "state": { "enum": ["fresh", "stale", "missing", "unverified"] }
            }
          },
          "allowed_wording": { "type": "string", "minLength": 1 }
        }
      }
    },
    "hooks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "text", "angle", "claim_ids"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "text": { "type": "string", "minLength": 1 },
          "angle": { "type": "string", "minLength": 1 },
          "claim_ids": { "type": "array", "items": { "$ref": "#/$defs/claimId" }, "uniqueItems": true }
        }
      }
    },
    "variants": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "text", "assertions", "action_affordances", "negative_feedback_review"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "text": { "type": "string", "minLength": 1 },
          "assertions": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/assertion" } },
          "action_affordances": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
          "negative_feedback_review": {
            "type": "object",
            "additionalProperties": false,
            "required": ["risk_level", "risks", "mitigations"],
            "properties": {
              "risk_level": { "enum": ["low", "medium", "high"] },
              "risks": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
              "mitigations": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true }
            }
          }
        }
      }
    },
    "assumptions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["text", "kind"],
        "properties": {
          "text": { "type": "string", "minLength": 1 },
          "kind": { "const": "assumption" }
        }
      }
    },
    "rejections": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "launch_plan": {
      "type": "object",
      "additionalProperties": false,
      "required": ["timing_rationale", "distribution_boundaries", "reply_handling"],
      "properties": {
        "timing_rationale": { "type": "string", "minLength": 1 },
        "distribution_boundaries": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
        "reply_handling": { "type": "string", "minLength": 1 }
      }
    },
    "measurement_plan": {
      "type": "object",
      "additionalProperties": false,
      "required": ["baseline", "observation_window", "metrics", "causal_limit"],
      "properties": {
        "baseline": { "type": "string", "minLength": 1 },
        "observation_window": { "type": "string", "minLength": 1 },
        "metrics": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
        "causal_limit": { "type": "string", "minLength": 1 }
      }
    },
    "limitations": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
    "extensions": { "type": "object" }
  },
  "allOf": [
    {
      "if": { "properties": { "status": { "const": "ready" } }, "required": ["status"] },
      "then": { "properties": { "variants": { "minItems": 1 } } }
    },
    {
      "if": { "properties": { "status": { "enum": ["needs-evidence", "rejected"] } }, "required": ["status"] },
      "then": {
        "properties": {
          "variants": { "maxItems": 0 },
          "rejections": { "minItems": 1 }
        }
      }
    }
  ]
}
